{
    "name": "react-json-virtualization",
    "version": "0.1.0",
    "description": "Virtualized React JSON viewer for very large JSON strings with token-based color theming.",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./styles.css": "./dist/styles.css"
    },
    "peerDependencies": {
        "react": ">=18"
    },
    "scripts": {
        "build": "tsup src/index.ts src/styles.css --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts src/styles.css --format cjs,esm --dts --watch",
        "demo": "vite --config demo/vite.config.ts",
        "demo:build": "vite build --config demo/vite.config.ts",
        "demo:preview": "vite preview --config demo/vite.config.ts",
        "bench:generate": "node bench/generate-fixtures.mjs",
        "bench:parse": "npm run build && node bench/run-parse-benchmark.mjs",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "devDependencies": {
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^6.0.1",
        "jsdom": "^25.0.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tsup": "^8.3.5",
        "typescript": "^5.7.2",
        "vite": "^8.0.3",
        "vitest": "^2.1.4"
    }
}
