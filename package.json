{
    "name": "react-json-virtualization",
    "version": "0.1.0",
    "description": "Virtualized React JSON viewer for very large JSON strings with token-based color theming.",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./styles.css": "./dist/styles.css"
    },
    "peerDependencies": {
        "react": ">=18"
    },
    "scripts": {
        "build": "tsup src/index.ts src/styles.css --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts src/styles.css --format cjs,esm --dts --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "devDependencies": {
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "typescript": "^5.7.2",
        "tsup": "^8.3.5",
        "vitest": "^2.1.4",
        "jsdom": "^25.0.1"
    }
}