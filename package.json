{
    "name": "react-json-virtualization",
    "version": "0.3.1",
    "description": "Virtualized React JSON viewer for very large JSON strings with token-based color theming.",
    "keywords": [
        "react",
        "json",
        "virtualized",
        "viewer",
        "typescript"
    ],
    "homepage": "https://github.com/MietoProgramming/react-json-virtualization#readme",
    "bugs": {
        "url": "https://github.com/MietoProgramming/react-json-virtualization/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MietoProgramming/react-json-virtualization.git"
    },
    "license": "MIT",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./styles.css": "./dist/styles.css"
    },
    "peerDependencies": {
        "react": ">=18"
    },
    "scripts": {
        "build": "tsup src/index.ts src/styles.css --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts src/styles.css --format cjs,esm --dts --watch",
        "prepublishOnly": "npm run typecheck && npm run test && npm run build",
        "demo": "vite --config demo/vite.config.ts",
        "demo:build": "vite build --config demo/vite.config.ts",
        "demo:preview": "vite preview --config demo/vite.config.ts",
        "bench:generate": "node bench/generate-fixtures.mjs",
        "bench:parse": "npm run build && node bench/run-parse-benchmark.mjs",
        "bench:modes": "npm run build && node bench/run-mode-benchmark.mjs",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --check",
        "format:write": "prettier . --write",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.5.0",
        "jsdom": "^25.0.1",
        "prettier": "^3.8.3",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tsup": "^8.3.5",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.59.0",
        "vite": "^8.0.3",
        "vitest": "^2.1.4"
    }
}
